<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Semcosm.HardwareConsole.App.Views.ThermalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:models="using:Semcosm.HardwareConsole.App.Models">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24">
            <controls:SectionHeader
                Title="Thermal"
                Description="Mock thermal policy chains that escalate fan, power, profile and scheduler actions as temperature walls are crossed."
                TitleFontSize="32" />

            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <controls:SectionHeader
                        Title="Thermal Chains"
                        Description="Preview-only staged thermal guardrails. No real hardware write occurs from this page."
                        TitleFontSize="22" />

                    <ListView
                        ItemsSource="{x:Bind ViewModel.Policies, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,16" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ThermalPolicyCardModel">
                                <controls:ThermalPolicyCard
                                    PolicyId="{x:Bind Id}"
                                    DisplayName="{x:Bind DisplayName}"
                                    Description="{x:Bind Description}"
                                    RiskLevel="{x:Bind RiskLevel}"
                                    ScopeText="{x:Bind ScopeText}"
                                    SensorSummary="{x:Bind SensorSummary}"
                                    ActionCountText="{x:Bind ActionCountText}"
                                    TimingText="{x:Bind TimingText}"
                                    ControlSummary="{x:Bind ControlSummary}"
                                    PreviewRequested="ThermalPolicyCard_PreviewRequested" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="16">
                        <controls:SectionHeader
                            Title="Thermal Preview"
                            Description="Preview shows staged thermal chain responses only. It does not write real hardware or start a runtime policy engine."
                            TitleFontSize="22" />

                        <controls:RiskBadge RiskLevel="{x:Bind ViewModel.Preview.RiskLevel, Mode=OneWay}" />
                        <controls:CapabilityChip Text="{x:Bind ViewModel.Preview.ScopeText, Mode=OneWay}" />

                        <StackPanel Spacing="8">
                            <TextBlock
                                Text="{x:Bind ViewModel.Preview.Title, Mode=OneWay}"
                                FontSize="20"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{x:Bind ViewModel.Preview.Description, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Opacity="0.76" />
                        </StackPanel>

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.InputSensorsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.WouldSetControlsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.StatusText, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.FailureCodeText, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.TimingSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.BlockedReasonsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.DiagnosticsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.Message, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <StackPanel Spacing="10">
                            <TextBlock Text="Threshold Actions" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.PreviewActions, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ThermalActionRowModel">
                                        <controls:ThermalActionRow
                                            Margin="0,0,0,10"
                                            StageLabel="{x:Bind StageLabel}"
                                            TriggerText="{x:Bind TriggerText}"
                                            DisplayName="{x:Bind DisplayName}"
                                            Subtitle="{x:Bind Subtitle}"
                                            TargetValue="{x:Bind TargetValue}"
                                            RiskLevel="{x:Bind RiskLevel}"
                                            ShowConfirmation="{x:Bind RequiresConfirmation}"
                                            ConfirmationText="{x:Bind ConfirmationText}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
