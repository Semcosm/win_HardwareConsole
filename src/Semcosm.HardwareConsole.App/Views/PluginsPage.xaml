<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Semcosm.HardwareConsole.App.Views.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24">

            <controls:SectionHeader
                Title="Plugins"
                Description="Hardware capability providers, policy extensions and device-specific control modules."
                TitleFontSize="32" />

            <Border
                Padding="20"
                CornerRadius="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="12">
                    <controls:SectionHeader
                        Title="Extension Model"
                        Description="Plugins declare devices, sensors, controls, policies, capabilities and risk level. The UI is generated from capabilities instead of hard-coded device brands."
                        TitleFontSize="22" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Padding="16"
                            CornerRadius="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Hardware Plugin" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <controls:CapabilityChip Text="Sensors" />
                                    <controls:CapabilityChip Text="Controls" />
                                    <controls:CapabilityChip Text="Drivers" />
                                </StackPanel>
                                <TextBlock Text="Sensors, fan control, power limits, voltage controls, EC/WMI/SDK access." TextWrapping="Wrap" Opacity="0.72" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="16"
                            CornerRadius="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Policy Plugin" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <controls:CapabilityChip Text="Curves" />
                                    <controls:CapabilityChip Text="Rules" />
                                    <controls:CapabilityChip Text="Automation" />
                                </StackPanel>
                                <TextBlock Text="Fan curves, thermal chains, scheduler rules, profile automation." TextWrapping="Wrap" Opacity="0.72" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="UI Extension" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <controls:CapabilityChip Text="Pages" />
                                    <controls:CapabilityChip Text="Cards" />
                                    <controls:CapabilityChip Text="Device UX" />
                                </StackPanel>
                                <TextBlock Text="Optional device-specific pages and cards for advanced hardware." TextWrapping="Wrap" Opacity="0.72" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <controls:SectionHeader
                Title="Installed Plugins"
                Description="Loaded extensions are rendered through a shared plugin card so Dashboard, Devices and Profiles can reuse the same visual language later."
                TitleFontSize="22" />

            <ListView
                ItemsSource="{x:Bind ViewModel.InstalledPlugins, Mode=OneWay}"
                SelectionMode="None">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,16" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <controls:PluginCard
                            DisplayName="{Binding DisplayName}"
                            Id="{Binding Id}"
                            State="{Binding StateText}"
                            RiskLevel="{Binding RiskLevel}"
                            Vendor="{Binding Vendor}"
                            Version="{Binding Version}"
                            CapabilitySummary="{Binding CapabilitySummary}"
                            MatchedDeviceSummary="{Binding MatchedDeviceSummary}"
                            Capabilities="{Binding Capabilities}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>
