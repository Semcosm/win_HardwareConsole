<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Semcosm.HardwareConsole.App.Views.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24">

            <StackPanel Spacing="8">
                <TextBlock
                    Text="Plugins"
                    FontSize="32"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="Hardware capability providers, policy extensions and device-specific control modules."
                    Opacity="0.72" />
            </StackPanel>

            <Border
                Padding="20"
                CornerRadius="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Extension Model"
                        FontSize="22"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="Plugins declare devices, sensors, controls, policies, capabilities and risk level. The UI is generated from capabilities instead of hard-coded device brands."
                        TextWrapping="Wrap"
                        Opacity="0.76" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Padding="16"
                            CornerRadius="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Hardware Plugin" FontWeight="SemiBold" />
                                <TextBlock Text="Sensors, fan control, power limits, voltage controls, EC/WMI/SDK access." TextWrapping="Wrap" Opacity="0.72" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="16"
                            CornerRadius="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Policy Plugin" FontWeight="SemiBold" />
                                <TextBlock Text="Fan curves, thermal chains, scheduler rules, profile automation." TextWrapping="Wrap" Opacity="0.72" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="16"
                            CornerRadius="12"
                            Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="UI Extension" FontWeight="SemiBold" />
                                <TextBlock Text="Optional device-specific pages and cards for advanced hardware." TextWrapping="Wrap" Opacity="0.72" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock
                Text="Installed Plugins"
                FontSize="22"
                FontWeight="SemiBold" />

            <ListView
                ItemsSource="{x:Bind ViewModel.InstalledPlugins, Mode=OneWay}"
                SelectionMode="None">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,16" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Padding="20"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="8">
                                    <TextBlock
                                        Text="{Binding DisplayName}"
                                        FontSize="20"
                                        FontWeight="SemiBold" />

                                    <TextBlock
                                        Text="{Binding Id}"
                                        FontFamily="Consolas"
                                        Opacity="0.68" />

                                    <TextBlock
                                        Text="{Binding MatchedDeviceSummary}"
                                        TextWrapping="Wrap"
                                        Opacity="0.76" />

                                    <TextBlock
                                        Text="{Binding CapabilitySummary}"
                                        TextWrapping="Wrap"
                                        Opacity="0.76" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="State:" Opacity="0.68" />
                                        <TextBlock Text="{Binding State}" FontWeight="SemiBold" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Risk:" Opacity="0.68" />
                                        <TextBlock Text="{Binding RiskLevelText}" FontWeight="SemiBold" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Vendor:" Opacity="0.68" />
                                        <TextBlock Text="{Binding Vendor}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Version:" Opacity="0.68" />
                                        <TextBlock Text="{Binding Version}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>
