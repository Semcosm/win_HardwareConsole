<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Semcosm.HardwareConsole.App.Views.FansPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:models="using:Semcosm.HardwareConsole.App.Models">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24">
            <controls:SectionHeader
                Title="Fans"
                Description="Mock fan policy editor that binds sensors to controls through fan curves and runtime preview, without writing real hardware."
                TitleFontSize="32" />

            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <controls:SectionHeader
                        Title="Fan Policies"
                        Description="CPU, GPU and platform policies all share the same mock curve editor pattern."
                        TitleFontSize="22" />

                    <ListView
                        ItemsSource="{x:Bind ViewModel.Policies, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,16" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:FanPolicyEditorModel">
                                <controls:FanCurveEditor
                                    PolicyId="{x:Bind PolicyId}"
                                    DisplayName="{x:Bind DisplayName}"
                                    Description="{x:Bind Description}"
                                    ScopeText="{x:Bind ScopeText}"
                                    PolicyText="{x:Bind PolicyText}"
                                    RiskLevel="{x:Bind RiskLevel}"
                                    InputSensorOptions="{x:Bind InputSensorOptions}"
                                    OutputControlOptions="{x:Bind OutputControlOptions}"
                                    SelectedInputSensorId="{x:Bind SelectedInputSensorId}"
                                    SelectedOutputControlId="{x:Bind SelectedOutputControlId}"
                                    CurvePoints="{x:Bind CurvePoints}"
                                    HysteresisText="{x:Bind HysteresisText}"
                                    RampUpText="{x:Bind RampUpText}"
                                    RampDownText="{x:Bind RampDownText}"
                                    PreviewRequested="FanCurveEditor_PreviewRequested" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="16">
                        <controls:SectionHeader
                            Title="Runtime Preview"
                            Description="Preview only shows would-set policy behavior. No real fan controller write occurs."
                            TitleFontSize="22" />

                        <controls:RiskBadge RiskLevel="{x:Bind ViewModel.Preview.RiskLevel, Mode=OneWay}" />
                        <controls:CapabilityChip Text="{x:Bind ViewModel.Preview.ScopeText, Mode=OneWay}" />

                        <StackPanel Spacing="8">
                            <TextBlock
                                Text="{x:Bind ViewModel.Preview.Title, Mode=OneWay}"
                                FontSize="20"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{x:Bind ViewModel.Preview.Description, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Opacity="0.76" />
                        </StackPanel>

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.InputSensorText, Mode=OneWay}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.OutputControlText, Mode=OneWay}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.WouldSetSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.TimingSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.Message, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <StackPanel Spacing="10">
                            <TextBlock Text="Curve Preview" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.PreviewCurvePoints, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:FanCurvePointRowModel">
                                        <controls:FanCurvePointRow
                                            Margin="0,0,0,10"
                                            InputText="{x:Bind InputText}"
                                            OutputText="{x:Bind OutputText}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
