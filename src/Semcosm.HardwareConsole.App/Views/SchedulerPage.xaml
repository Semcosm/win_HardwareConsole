<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Semcosm.HardwareConsole.App.Views.SchedulerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:models="using:Semcosm.HardwareConsole.App.Models">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24">
            <controls:SectionHeader
                Title="Scheduler"
                Description="Mock process-rule scheduler policies for EcoQoS, efficiency mode, foreground boost and background throttling."
                TitleFontSize="32" />

            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <controls:SectionHeader
                        Title="Scheduler Policies"
                        Description="Preview-only process scheduling rules. No real Windows scheduler write occurs."
                        TitleFontSize="22" />

                    <ListView
                        ItemsSource="{x:Bind ViewModel.Policies, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,16" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:SchedulerPolicyCardModel">
                                <controls:SchedulerPolicyCard
                                    PolicyId="{x:Bind Id}"
                                    DisplayName="{x:Bind DisplayName}"
                                    Description="{x:Bind Description}"
                                    RiskLevel="{x:Bind RiskLevel}"
                                    ScopeText="{x:Bind ScopeText}"
                                    RuleCountText="{x:Bind RuleCountText}"
                                    TriggerSummary="{x:Bind TriggerSummary}"
                                    ForegroundStrategyText="{x:Bind ForegroundStrategyText}"
                                    BackgroundStrategyText="{x:Bind BackgroundStrategyText}"
                                    ControlSummary="{x:Bind ControlSummary}"
                                    PreviewRequested="SchedulerPolicyCard_PreviewRequested" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="16">
                        <controls:SectionHeader
                            Title="Scheduler Preview"
                            Description="Preview shows process-rule intent only. No real scheduler, EcoQoS or efficiency-mode write occurs."
                            TitleFontSize="22" />

                        <controls:RiskBadge RiskLevel="{x:Bind ViewModel.Preview.RiskLevel, Mode=OneWay}" />
                        <controls:CapabilityChip Text="{x:Bind ViewModel.Preview.ScopeText, Mode=OneWay}" />

                        <StackPanel Spacing="8">
                            <TextBlock
                                Text="{x:Bind ViewModel.Preview.Title, Mode=OneWay}"
                                FontSize="20"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{x:Bind ViewModel.Preview.Description, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Opacity="0.76" />
                        </StackPanel>

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.RequiredSensorsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.WouldSetControlsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.StatusText, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.FailureCodeText, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.ForegroundStrategyText, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.BackgroundStrategyText, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.BlockedReasonsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.DiagnosticsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.Message, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <StackPanel Spacing="10">
                            <TextBlock Text="Process Rules" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.PreviewRules, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:SchedulerRuleRowModel">
                                        <controls:SchedulerRuleRow
                                            Margin="0,0,0,10"
                                            DisplayName="{x:Bind DisplayName}"
                                            MatchText="{x:Bind MatchText}"
                                            Description="{x:Bind Description}"
                                            ActionSummary="{x:Bind ActionSummary}"
                                            RiskLevel="{x:Bind RiskLevel}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
