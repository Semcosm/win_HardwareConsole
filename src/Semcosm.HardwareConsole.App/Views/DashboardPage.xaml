<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Semcosm.HardwareConsole.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24">
            <controls:SectionHeader
                Title="Dashboard"
                Description="System overview, active profile, sensors and hardware state."
                TitleFontSize="32" />

            <GridView
                ItemsSource="{x:Bind ViewModel.SummaryCards, Mode=OneWay}"
                SelectionMode="None"
                IsItemClickEnabled="False">

                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,16,16" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>

                <GridView.ItemTemplate>
                    <DataTemplate>
                        <controls:MetricCard
                            Title="{Binding Title}"
                            Subtitle="{Binding Subtitle}"
                            PrimaryValue="{Binding PrimaryValue}"
                            SecondaryValue="{Binding SecondaryValue}"
                            Status="{Binding Status}"
                            CardWidth="400"
                            MinCardHeight="132"
                            PrimaryFontSize="24" />
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <controls:SectionHeader
                Title="Control State"
                Description="Current control surfaces and policy outputs driven by the active hardware profile."
                TitleFontSize="22" />

            <GridView
                ItemsSource="{x:Bind ViewModel.DetailCards, Mode=OneWay}"
                SelectionMode="None"
                IsItemClickEnabled="False">

                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,16,16" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </GridView.ItemContainerStyle>

                <GridView.ItemTemplate>
                    <DataTemplate>
                        <controls:MetricCard
                            Title="{Binding Title}"
                            Subtitle="{Binding Subtitle}"
                            PrimaryValue="{Binding PrimaryValue}"
                            SecondaryValue="{Binding SecondaryValue}"
                            Status="{Binding Status}"
                            CardWidth="620"
                            MinCardHeight="132"
                            PrimaryFontSize="22" />
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>
