<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Semcosm.HardwareConsole.App.Views.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:models="using:Semcosm.HardwareConsole.App.Models">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24">
            <controls:SectionHeader
                Title="Diagnostics"
                Description="Unified diagnostics plane for routes, plugins, profile apply, fan preview and thermal validation."
                TitleFontSize="32" />

            <StackPanel Spacing="16">
                <controls:SectionHeader
                    Title="System Health"
                    Description="Latest diagnostic state for each major runtime surface."
                    TitleFontSize="22" />

                <GridView
                    ItemsSource="{x:Bind ViewModel.SystemHealth, Mode=OneWay}"
                    SelectionMode="None"
                    IsItemClickEnabled="False">

                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,16,16" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </GridView.ItemContainerStyle>

                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:DiagnosticCardModel">
                            <controls:DiagnosticCard
                                Width="360"
                                Title="{x:Bind Title}"
                                StatusText="{x:Bind StatusText}"
                                DetailsText="{x:Bind DetailsText}"
                                SourceText="{x:Bind SourceText}"
                                SeverityText="{x:Bind SeverityText}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

            <StackPanel Spacing="16">
                <controls:SectionHeader
                    Title="Diagnostic Log"
                    Description="Historical diagnostic records across the current session."
                    TitleFontSize="22" />

                <ListView
                    ItemsSource="{x:Bind ViewModel.DiagnosticLog, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,12" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DiagnosticRecordModel">
                            <controls:DiagnosticRow
                                SeverityText="{x:Bind SeverityText}"
                                SourceText="{x:Bind SourceText}"
                                Code="{x:Bind Code}"
                                Message="{x:Bind Message}"
                                RelatedId="{x:Bind RelatedId}"
                                TimestampText="{x:Bind TimestampText}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
