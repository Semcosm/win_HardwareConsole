<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Semcosm.HardwareConsole.App.Views.PowerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:models="using:Semcosm.HardwareConsole.App.Models">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24">
            <controls:SectionHeader
                Title="Power"
                Description="Mock Windows power-plan behavior, AC/DC transitions and CPU/GPU budget policies without writing real hardware."
                TitleFontSize="32" />

            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <controls:SectionHeader
                        Title="Power Policies"
                        Description="Preview-only AC/DC policy surfaces for Windows power plans and CPU/GPU budgets."
                        TitleFontSize="22" />

                    <ListView
                        ItemsSource="{x:Bind ViewModel.Policies, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,16" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:PowerPolicyCardModel">
                                <controls:PowerPolicyCard
                                    PolicyId="{x:Bind Id}"
                                    DisplayName="{x:Bind DisplayName}"
                                    Description="{x:Bind Description}"
                                    RiskLevel="{x:Bind RiskLevel}"
                                    ScopeText="{x:Bind ScopeText}"
                                    PlanText="{x:Bind PlanText}"
                                    TriggerSummary="{x:Bind TriggerSummary}"
                                    ActionCountText="{x:Bind ActionCountText}"
                                    AcBehaviorText="{x:Bind AcBehaviorText}"
                                    DcBehaviorText="{x:Bind DcBehaviorText}"
                                    ControlSummary="{x:Bind ControlSummary}"
                                    PreviewRequested="PowerPolicyCard_PreviewRequested" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="20"
                    CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="16">
                        <controls:SectionHeader
                            Title="Power Preview"
                            Description="Preview shows would-set plan and control targets only. No real Windows power write occurs."
                            TitleFontSize="22" />

                        <controls:RiskBadge RiskLevel="{x:Bind ViewModel.Preview.RiskLevel, Mode=OneWay}" />
                        <controls:CapabilityChip Text="{x:Bind ViewModel.Preview.ScopeText, Mode=OneWay}" />

                        <StackPanel Spacing="8">
                            <TextBlock
                                Text="{x:Bind ViewModel.Preview.Title, Mode=OneWay}"
                                FontSize="20"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{x:Bind ViewModel.Preview.Description, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Opacity="0.76" />
                        </StackPanel>

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.PlanText, Mode=OneWay}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.RequiredSensorsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.WouldSetControlsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.StatusText, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.FailureCodeText, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.AcBehaviorText, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.DcBehaviorText, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.BlockedReasonsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.DiagnosticsSummary, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Preview.Message, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Opacity="0.76" />

                        <StackPanel Spacing="10">
                            <TextBlock Text="AC/DC Action Targets" FontWeight="SemiBold" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.PreviewActions, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ProfileActionRowModel">
                                        <controls:ProfileActionRow
                                            Margin="0,0,0,10"
                                            DisplayName="{x:Bind DisplayName}"
                                            Subtitle="{x:Bind Subtitle}"
                                            TargetValue="{x:Bind TargetValue}"
                                            RiskLevel="{x:Bind RiskLevel}"
                                            ShowConfirmation="{x:Bind RequiresConfirmation}"
                                            ConfirmationText="{x:Bind ConfirmationText}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
