<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Semcosm.HardwareConsole.App.Views.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:models="using:Semcosm.HardwareConsole.App.Models">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24">
            <controls:SectionHeader
                Title="Profiles"
                Description="Profile presets, switching rules and control bundles powered by the mock profile runtime."
                TitleFontSize="32" />

            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="24">
                    <controls:SectionHeader
                        Title="Current Active Profile"
                        Description="The active profile now comes from the profile runtime, not mock profile sensor values."
                        TitleFontSize="22" />

                    <ContentControl Content="{x:Bind ViewModel.ActiveProfile, Mode=OneWay}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate x:DataType="models:ProfileCardModel">
                                <controls:ProfileCard
                                    ProfileId="{x:Bind Id}"
                                    DisplayName="{x:Bind DisplayName}"
                                    Description="{x:Bind Description}"
                                    RiskLevel="{x:Bind RiskLevel}"
                                    SourceText="{x:Bind SourceText}"
                                    CapabilityCountText="{x:Bind CapabilityCountText}"
                                    ActionCountText="{x:Bind ActionCountText}"
                                    PolicyCountText="{x:Bind PolicyCountText}"
                                    ShowConfirmation="{x:Bind RequiresConfirmation}"
                                    ConfirmationText="{x:Bind ConfirmationText}"
                                    IsApplyEnabled="{x:Bind IsApplyEnabled}"
                                    IsActive="{x:Bind IsActive}"
                                    PreviewRequested="ProfileCard_PreviewRequested"
                                    ApplyRequested="ProfileCard_ApplyRequested" />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <controls:SectionHeader
                        Title="Built-in Profiles"
                        Description="Factory presets that bundle capabilities, control targets and policies."
                        TitleFontSize="22" />

                    <ListView
                        ItemsSource="{x:Bind ViewModel.BuiltInProfiles, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,16" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ProfileCardModel">
                                <controls:ProfileCard
                                    ProfileId="{x:Bind Id}"
                                    DisplayName="{x:Bind DisplayName}"
                                    Description="{x:Bind Description}"
                                    RiskLevel="{x:Bind RiskLevel}"
                                    SourceText="{x:Bind SourceText}"
                                    CapabilityCountText="{x:Bind CapabilityCountText}"
                                    ActionCountText="{x:Bind ActionCountText}"
                                    PolicyCountText="{x:Bind PolicyCountText}"
                                    ShowConfirmation="{x:Bind RequiresConfirmation}"
                                    ConfirmationText="{x:Bind ConfirmationText}"
                                    IsApplyEnabled="{x:Bind IsApplyEnabled}"
                                    IsActive="{x:Bind IsActive}"
                                    PreviewRequested="ProfileCard_PreviewRequested"
                                    ApplyRequested="ProfileCard_ApplyRequested" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <controls:SectionHeader
                        Title="Custom Profiles"
                        Description="User and vendor-provided presets live alongside the built-in library."
                        TitleFontSize="22" />

                    <ListView
                        ItemsSource="{x:Bind ViewModel.CustomProfiles, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,16" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ProfileCardModel">
                                <controls:ProfileCard
                                    ProfileId="{x:Bind Id}"
                                    DisplayName="{x:Bind DisplayName}"
                                    Description="{x:Bind Description}"
                                    RiskLevel="{x:Bind RiskLevel}"
                                    SourceText="{x:Bind SourceText}"
                                    CapabilityCountText="{x:Bind CapabilityCountText}"
                                    ActionCountText="{x:Bind ActionCountText}"
                                    PolicyCountText="{x:Bind PolicyCountText}"
                                    ShowConfirmation="{x:Bind RequiresConfirmation}"
                                    ConfirmationText="{x:Bind ConfirmationText}"
                                    IsApplyEnabled="{x:Bind IsApplyEnabled}"
                                    IsActive="{x:Bind IsActive}"
                                    PreviewRequested="ProfileCard_PreviewRequested"
                                    ApplyRequested="ProfileCard_ApplyRequested" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="16">
                    <controls:ProfilePreviewPanel
                        Title="{x:Bind ViewModel.Preview.Title, Mode=OneWay}"
                        Description="{x:Bind ViewModel.Preview.Description, Mode=OneWay}"
                        StatusText="{x:Bind ViewModel.Preview.StatusText, Mode=OneWay}"
                        SourceText="{x:Bind ViewModel.Preview.SourceText, Mode=OneWay}"
                        RiskLevel="{x:Bind ViewModel.Preview.RiskLevel, Mode=OneWay}"
                        ShowConfirmation="{x:Bind ViewModel.Preview.RequiresConfirmation, Mode=OneWay}"
                        ConfirmationText="{x:Bind ViewModel.Preview.ConfirmationText, Mode=OneWay}"
                        ShowEmptyState="{x:Bind ViewModel.Preview.ShowEmptyState, Mode=OneWay}"
                        EmptyTitle="{x:Bind ViewModel.Preview.EmptyTitle, Mode=OneWay}"
                        EmptyDescription="{x:Bind ViewModel.Preview.EmptyDescription, Mode=OneWay}"
                        Actions="{x:Bind ViewModel.PreviewActions, Mode=OneWay}" />

                    <Border
                        x:Name="ConfirmationGatePanel"
                        Padding="16"
                        CornerRadius="16"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        x:Load="{x:Bind ViewModel.ShowConfirmationGate, Mode=OneWay}">
                        <StackPanel Spacing="12">
                            <TextBlock
                                Text="Mock Apply Confirmation"
                                FontSize="18"
                                FontWeight="SemiBold" />

                            <TextBlock
                                Text="{x:Bind ViewModel.ConfirmationBannerText, Mode=OneWay}"
                                TextWrapping="Wrap"
                                Opacity="0.76" />

                            <CheckBox
                                x:Name="ConfirmationCheckBox"
                                IsChecked="{x:Bind ViewModel.IsApplyConfirmed, Mode=OneWay}"
                                Checked="ConfirmationCheckBox_Checked"
                                Unchecked="ConfirmationCheckBox_Unchecked">
                                <TextBlock
                                    Text="{x:Bind ViewModel.ConfirmationCheckText, Mode=OneWay}"
                                    TextWrapping="Wrap" />
                            </CheckBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
