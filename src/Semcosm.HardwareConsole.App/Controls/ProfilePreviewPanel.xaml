<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Semcosm.HardwareConsole.App.Controls.ProfilePreviewPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:local="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:models="using:Semcosm.HardwareConsole.App.Models"
    x:DataType="local:ProfilePreviewPanel"
    x:Name="Root">

    <Border
        Padding="20"
        CornerRadius="16"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

        <Grid>
            <StackPanel
                x:Name="EmptyStatePanel"
                Spacing="12"
                x:Load="{x:Bind ShowEmptyState, Mode=OneWay}">
                <TextBlock
                    Text="{x:Bind EmptyTitle, Mode=OneWay}"
                    FontSize="22"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="{x:Bind EmptyDescription, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Opacity="0.72" />
            </StackPanel>

            <StackPanel
                x:Name="ContentPanel"
                Spacing="16"
                x:Load="{x:Bind ShowContent, Mode=OneWay}">
                <StackPanel Spacing="8">
                    <TextBlock
                        Text="{x:Bind Title, Mode=OneWay}"
                        FontSize="22"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="{x:Bind Description, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Opacity="0.76" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <controls:RiskBadge RiskLevel="{x:Bind RiskLevel, Mode=OneWay}" />
                    <controls:CapabilityChip Text="{x:Bind SourceText, Mode=OneWay}" />
                    <controls:CapabilityChip
                        x:Name="ConfirmationChip"
                        Text="{x:Bind ConfirmationText, Mode=OneWay}"
                        x:Load="{x:Bind ShowConfirmation, Mode=OneWay}" />
                </StackPanel>

                <TextBlock
                    Text="{x:Bind StatusText, Mode=OneWay}"
                    TextWrapping="Wrap"
                    Opacity="0.76" />

                <ItemsControl ItemsSource="{x:Bind Actions, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ProfileActionRowModel">
                            <controls:ProfileActionRow
                                Margin="0,0,0,12"
                                DisplayName="{x:Bind DisplayName}"
                                Subtitle="{x:Bind Subtitle}"
                                TargetValue="{x:Bind TargetValue}"
                                RiskLevel="{x:Bind RiskLevel}"
                                ShowConfirmation="{x:Bind RequiresConfirmation}"
                                ConfirmationText="{x:Bind ConfirmationText}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
