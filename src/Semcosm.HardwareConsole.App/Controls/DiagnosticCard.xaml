<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Semcosm.HardwareConsole.App.Controls.DiagnosticCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:local="using:Semcosm.HardwareConsole.App.Controls"
    x:DataType="local:DiagnosticCard"
    x:Name="Root">

    <Border
        Padding="20"
        CornerRadius="16"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
        <StackPanel Spacing="12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock
                        Text="{x:Bind Title, Mode=OneWay}"
                        FontSize="20"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="{x:Bind SourceText, Mode=OneWay}"
                        Opacity="0.68" />
                </StackPanel>

                <controls:CapabilityChip
                    Grid.Column="1"
                    Text="{x:Bind SeverityText, Mode=OneWay}" />
            </Grid>

            <TextBlock
                Text="{x:Bind StatusText, Mode=OneWay}"
                FontSize="24"
                FontWeight="SemiBold" />

            <TextBlock
                Text="{x:Bind DetailsText, Mode=OneWay}"
                TextWrapping="Wrap"
                Opacity="0.76" />
        </StackPanel>
    </Border>
</UserControl>
