<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Semcosm.HardwareConsole.App.Controls.PluginCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    x:Name="Root">

    <Border
        Padding="20"
        CornerRadius="16"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

        <StackPanel Spacing="16">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock
                        Text="{x:Bind Root.DisplayName, Mode=OneWay}"
                        FontSize="20"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="{x:Bind Root.Id, Mode=OneWay}"
                        FontFamily="Consolas"
                        Opacity="0.68" />

                    <TextBlock
                        Text="{x:Bind Root.MatchedDeviceSummary, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Opacity="0.76" />

                    <TextBlock
                        Text="{x:Bind Root.CapabilitySummary, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Opacity="0.76" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="State:" Opacity="0.68" />
                        <TextBlock Text="{x:Bind Root.State, Mode=OneWay}" FontWeight="SemiBold" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Risk:" Opacity="0.68" />
                        <controls:RiskBadge RiskLevel="{x:Bind Root.RiskLevel, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Vendor:" Opacity="0.68" />
                        <TextBlock Text="{x:Bind Root.Vendor, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Version:" Opacity="0.68" />
                        <TextBlock Text="{x:Bind Root.Version, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel Spacing="10">
                <TextBlock Text="Capabilities" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{x:Bind Root.Capabilities, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <controls:CapabilityChip
                                Margin="0,0,8,8"
                                Text="{x:Bind}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
