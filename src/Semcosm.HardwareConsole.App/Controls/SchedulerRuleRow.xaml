<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Semcosm.HardwareConsole.App.Controls.SchedulerRuleRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:local="using:Semcosm.HardwareConsole.App.Controls"
    x:DataType="local:SchedulerRuleRow"
    x:Name="Root">

    <Border
        Padding="16"
        CornerRadius="14"
        Background="{ThemeResource LayerFillColorDefaultBrush}">

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock
                    Text="{x:Bind DisplayName, Mode=OneWay}"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="{x:Bind MatchText, Mode=OneWay}"
                    Opacity="0.68"
                    TextWrapping="Wrap" />

                <TextBlock
                    Text="{x:Bind Description, Mode=OneWay}"
                    Opacity="0.76"
                    TextWrapping="Wrap" />

                <TextBlock
                    Text="{x:Bind ActionSummary, Mode=OneWay}"
                    Opacity="0.68"
                    TextWrapping="Wrap" />
            </StackPanel>

            <controls:RiskBadge
                Grid.Column="1"
                HorizontalAlignment="Right"
                RiskLevel="{x:Bind RiskLevel, Mode=OneWay}" />
        </Grid>
    </Border>
</UserControl>
