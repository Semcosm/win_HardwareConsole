<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Semcosm.HardwareConsole.App.Controls.FanCurveEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:local="using:Semcosm.HardwareConsole.App.Controls"
    xmlns:models="using:Semcosm.HardwareConsole.App.Models"
    x:DataType="local:FanCurveEditor"
    x:Name="Root">

    <Border
        Padding="20"
        CornerRadius="16"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
        <StackPanel Spacing="16">
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock
                        Text="{x:Bind DisplayName, Mode=OneWay}"
                        FontSize="22"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="{x:Bind Description, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Opacity="0.76" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8">
                    <controls:RiskBadge RiskLevel="{x:Bind RiskLevel, Mode=OneWay}" />
                    <controls:CapabilityChip Text="{x:Bind ScopeText, Mode=OneWay}" />
                </StackPanel>
            </Grid>

            <controls:CapabilityChip Text="{x:Bind PolicyText, Mode=OneWay}" />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="Input Sensor" FontWeight="SemiBold" />
                    <ComboBox
                        ItemsSource="{x:Bind InputSensorOptions, Mode=OneWay}"
                        DisplayMemberPath="DisplayName"
                        SelectedValuePath="Id"
                        SelectedValue="{x:Bind SelectedInputSensorId, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="Output Control" FontWeight="SemiBold" />
                    <ComboBox
                        ItemsSource="{x:Bind OutputControlOptions, Mode=OneWay}"
                        DisplayMemberPath="DisplayName"
                        SelectedValuePath="Id"
                        SelectedValue="{x:Bind SelectedOutputControlId, Mode=TwoWay}" />
                </StackPanel>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="12"
                    CornerRadius="12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Hysteresis" Opacity="0.68" />
                        <TextBlock Text="{x:Bind HysteresisText, Mode=OneWay}" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="12"
                    CornerRadius="12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Ramp-up" Opacity="0.68" />
                        <TextBlock Text="{x:Bind RampUpText, Mode=OneWay}" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Padding="12"
                    CornerRadius="12"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Ramp-down" Opacity="0.68" />
                        <TextBlock Text="{x:Bind RampDownText, Mode=OneWay}" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Spacing="10">
                <TextBlock Text="Curve Points" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{x:Bind CurvePoints, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:FanCurvePointRowModel">
                            <controls:FanCurvePointRow
                                Margin="0,0,0,10"
                                InputText="{x:Bind InputText}"
                                OutputText="{x:Bind OutputText}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Button
                Content="Preview Mock Policy"
                Click="PreviewButton_Click" />
        </StackPanel>
    </Border>
</UserControl>
