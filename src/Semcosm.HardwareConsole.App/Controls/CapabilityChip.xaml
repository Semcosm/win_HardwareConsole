<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Semcosm.HardwareConsole.App.Controls.CapabilityChip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Semcosm.HardwareConsole.App.Controls"
    x:DataType="local:CapabilityChip"
    x:Name="Root">

    <Border
        Padding="10,4"
        CornerRadius="999"
        Background="{ThemeResource LayerFillColorDefaultBrush}">
        <TextBlock
            Text="{x:Bind Text, Mode=OneWay}"
            FontSize="12"
            Opacity="0.86" />
    </Border>
</UserControl>
