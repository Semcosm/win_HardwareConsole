<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Semcosm.HardwareConsole.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Semcosm Hardware Console">

    <muxc:NavigationView
        x:Name="RootNavigationView"
        PaneTitle="Semcosm Hardware Console"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        SelectionChanged="RootNavigationView_SelectionChanged">

        <muxc:NavigationView.MenuItems>
            <muxc:NavigationViewItem Content="Dashboard" Tag="dashboard" />
            <muxc:NavigationViewItem Content="Performance" Tag="performance" />
            <muxc:NavigationViewItem Content="Fans" Tag="fans" />
            <muxc:NavigationViewItem Content="Power" Tag="power" />
            <muxc:NavigationViewItem Content="Thermal" Tag="thermal" />
            <muxc:NavigationViewItem Content="Scheduler" Tag="scheduler" />
            <muxc:NavigationViewItem Content="Devices" Tag="devices" />
            <muxc:NavigationViewItem Content="Plugins" Tag="plugins" />
            <muxc:NavigationViewItem Content="Profiles" Tag="profiles" />
            <muxc:NavigationViewItem Content="Diagnostics" Tag="diagnostics" />
        </muxc:NavigationView.MenuItems>

        <muxc:NavigationView.FooterMenuItems>
            <muxc:NavigationViewItem Content="Settings" Tag="settings" />
        </muxc:NavigationView.FooterMenuItems>

        <Frame x:Name="ContentFrame" />
    </muxc:NavigationView>
</Window>
